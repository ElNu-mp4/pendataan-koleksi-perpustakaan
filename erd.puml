@startuml
hide circle
skinparam linetype ortho
skinparam packageStyle rect

rectangle "Modul Pendataan" {
  entity "identitas_input_koleksi" as identitas_input_koleksi {
    * id_koleksi : int
    --
    nomor_pokok : varchar(50)
    tahun_data : year(4)
    tanggal_submit : datetime
    ip_address : varchar(50)
    session_id : varchar(100)
  }

  entity "jawaban_koleksi" as jawaban_koleksi {
    * id_jawaban : int
    --
    id_koleksi : int
    id_pertanyaan : int
    jawaban : text
  }

  entity "pertanyaan_koleksi" as pertanyaan_koleksi {
    * id_pertanyaan : int
    --
    section : int
    isi_pertanyaan : text
    tipe_jawaban : enum
    wajib : tinyint
    min_value : int
    max_value : int
    urutan : int
    aktif : tinyint
  }

  entity "opsi_pertanyaan_koleksi" as opsi_pertanyaan_koleksi {
    * id_opsi : int
    --
    id_pertanyaan : int
    label_opsi : varchar(255)
    nilai_opsi : varchar(100)
    urutan : int
    aktif : tinyint
  }

  entity "config_pendataan" as config_pendataan {
    * id : int
    --
    tahun_aktif : varchar(4)
    status_pendataan : enum
    pesan_nonaktif : text
  }
}

rectangle "Modul Autentikasi & Akses" {
  entity "users" as users {
    * username : varchar(50)
    --
    password : varchar(255)
    nama_lengkap : varchar(100)
    email : varchar(100)
    no_telp : varchar(20)
    foto : varchar(100)
    level : varchar(20)
    blokir : enum
    id_session : varchar(255)
  }

  entity "modul" as modul {
    * id_modul : int
    --
    nama_modul : varchar(50)
    link : varchar(100)
    publish : enum
    status : enum
    aktif : enum
  }

  entity "users_modul" as users_modul {
    * id_umod : int
    --
    id_session : varchar(255)
    id_modul : int
  }
}

rectangle "Modul CMS" {
  entity "kategori" as kategori {
    * id_kategori : int
    --
    nama_kategori : varchar(50)
    kategori_seo : varchar(100)
    aktif : enum
    sidebar : int
  }

  entity "berita" as berita {
    * id_berita : int
    --
    id_kategori : int
    username : varchar(30)
    judul : varchar(500)
    judul_seo : varchar(100)
    headline : enum
    aktif : enum
    utama : enum
    isi_berita : longtext
    gambar : varchar(100)
    dibaca : int
    tag : varchar(100)
    status : enum
  }

  entity "komentar" as komentar {
    * id_komentar : int
    --
    id_berita : int
    nama_komentar : varchar(100)
    isi_komentar : text
    tgl : date
    jam_komentar : time
    aktif : enum
    email : varchar(100)
  }

  entity "album" as album {
    * id_album : int
    --
    jdl_album : varchar(100)
    album_seo : varchar(100)
    aktif : enum
  }

  entity "gallery" as gallery {
    * id_gallery : int
    --
    id_album : int
    username : varchar(50)
    jdl_gallery : varchar(100)
    gallery_seo : varchar(100)
  }

  entity "playlist" as playlist {
    * id_playlist : int
    --
    jdl_playlist : varchar(100)
    username : varchar(50)
    playlist_seo : varchar(100)
    aktif : enum
  }

  entity "video" as video {
    * id_video : int
    --
    id_playlist : int
    username : varchar(30)
    jdl_video : varchar(100)
    video_seo : varchar(100)
    keterangan : text
    gbr_video : varchar(100)
    video : varchar(100)
    youtube : varchar(100)
    tagvid : varchar(100)
  }

  entity "komentarvid" as komentarvid {
    * id_komentar : int
    --
    id_video : int
    nama_komentar : varchar(100)
    isi_komentar : text
    tgl : date
    jam_komentar : time
    aktif : enum
  }
}

' Modul Pendataan
identitas_input_koleksi ||--o{ jawaban_koleksi : "has"
pertanyaan_koleksi ||--o{ jawaban_koleksi : "answered in"
pertanyaan_koleksi ||--o{ opsi_pertanyaan_koleksi : "defines"

' Modul Auth
users ||--o{ users_modul : "has permissions"
modul ||--o{ users_modul : "is assigned to"

' Modul CMS
kategori ||--o{ berita : "categorizes"
users ||--o{ berita : "authors"
berita ||--o{ komentar : "receives"
album ||--o{ gallery : "contains"
users ||--o{ gallery : "uploads"
playlist ||--o{ video : "contains"
users ||--o{ video : "uploads"
users ||--o{ playlist : "creates"
video ||--o{ komentarvid : "receives"

note bottom of config_pendataan
  Entitas standalone.
  Tidak berelasi dengan tabel lain;
  dikontrol langsung oleh administrator
  melalui panel admin.
end note

note bottom of jawaban_koleksi
  Hanya relasi ini yang di-enforce
  oleh MySQL foreign key constraint:
  jawaban_koleksi.id_koleksi →
  identitas_input_koleksi.id_koleksi.
  Relasi lain adalah application-level.
end note

@enduml