@startuml Flow Chart - User Journey (Detailed)

title User Journey Flow Chart

start

:Visit website (index.php);

:Load main page (Main controller);

:Display homepage with news, banners, etc.;

if (User type?) then (public)
  :Browse content;
  fork
    :Read news (Berita controller);
    :View categories and comments;
  fork again
    :View albums/galleries (Albums controller);
    :Browse photos;
  fork again
    :Watch videos/playlists (Playlist controller);
    :View comments;
  fork again
    :Access survey (Pendataan controller);
    :Check survey status;
    if (Active?) then (yes)
      :Fill survey form;
      :Submit (see Activity Diagram);
    else (no)
      :View inactive message;
    endif
  fork again
    :Contact (Hubungi controller);
    :Send message;
  fork again
    :Download files;
    :View polls;
  end fork
else (admin)
  :Login to admin panel;
  :Validate via users table;
  if (Authorized?) then (yes)
    fork
      :Manage News (berita, kategori, komentar);
      :CRUD operations;
    fork again
      :Manage Media (album, gallery, playlist, video, komentarvid);
      :Upload files, organize content;
    fork again
      :Manage Survey (see BPMN);
      :Questions, config, results;
    fork again
      :System Settings (identitas, menu, templates);
      :Configure site;
    fork again
      :User Management;
      :Manage users and permissions;
    end fork
  else (no)
    :Access denied;
  endif
endif

:Exit site;

stop

@enduml