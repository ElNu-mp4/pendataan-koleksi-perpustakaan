@startuml Activity Diagram - Pendataan Admin Flow

title Pendataan Flow dari Sudut Pandang Admin

start

partition Admin {
  :Buka halaman login administrator;
  :Masuk dengan kredensial;
  if (Login berhasil?) then (yes)
    :Melihat dashboard admin;
    if (Pilih manajemen pendataan?) then (yes)
      :Melihat daftar laporan pendataan;
      if (Tambah data baru?) then (yes)
        :Mengisi form pendataan baru;
        :Menyimpan data;
      endif
      if (Edit data?) then (yes)
        :Mengubah dan menyimpan data pendataan;
      endif
      if (Hapus data?) then (yes)
        :Menghapus catatan pendataan;
      endif
      if (Lihat detail?) then (yes)
        :Melihat detail pendataan;
      endif
    endif
    if (Buka debug pendataan?) then (yes)
      :Mengakses halaman debug pendataan;
    endif
  else (no)
    :Melihat pesan login gagal;
  endif
}

stop

@enduml