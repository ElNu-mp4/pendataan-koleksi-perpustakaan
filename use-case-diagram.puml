@startuml Use Case Diagram - Library Data Collection System
left to right direction
skinparam actorBackgroundColor #F8F8F8
skinparam actorBorderColor #333333
skinparam usecaseBackgroundColor #FFFFFF
skinparam usecaseBorderColor #333333
skinparam packageBackgroundColor #E8F4F8

title Library Data Collection System - Use Case Diagram
caption Dinas Kearsipan dan Perpustakaan Jawa Tengah

actor Admin
actor "Operator/Staff" as Operator
actor "Guest/Viewer" as Guest

rectangle "Library Data Collection System" {
    
    ' ════════════════════════════════════════════════════════════════════
    ' AUTHENTICATION MODULE
    ' ════════════════════════════════════════════════════════════════════
    package "Authentication" #E8F4F8 {
        usecase "Login" as UC_Login
        usecase "Logout" as UC_Logout
        usecase "Manage Session" as UC_Manage_Session
    }
    
    ' ════════════════════════════════════════════════════════════════════
    ' LIBRARY DATA ENTRY MODULE
    ' ════════════════════════════════════════════════════════════════════
    package "Library Data Entry" #E8F4F8 {
        usecase "View Survey Form" as UC_View_Form
        usecase "Input Library Data" as UC_Input_Data
        usecase "Validate Input Data" as UC_Validate
        usecase "Check Rate Limit" as UC_Check_Rate
        usecase "Prevent Double Submission" as UC_Double_Submit
        usecase "Submit Data" as UC_Submit
        usecase "View Confirmation Page" as UC_Confirmation
    }
    
    ' ════════════════════════════════════════════════════════════════════
    ' RECAP & STATISTICS MODULE
    ' ════════════════════════════════════════════════════════════════════
    package "Recap & Statistics" #E8F4F8 {
        usecase "View Recap Page" as UC_View_Recap
        usecase "Filter Data by Year" as UC_Filter_Year
        usecase "Filter Data by Date Range" as UC_Filter_Date
        usecase "Filter Data by Reference Number" as UC_Filter_Nomor
        usecase "Sort Data" as UC_Sort_Data
        usecase "View Detail Data" as UC_View_Detail
        usecase "View Chart Statistics" as UC_View_Charts
        usecase "Export to Excel" as UC_Export_Excel
        usecase "Check Export Rate Limit" as UC_Export_Rate_Limit
    }
    
    ' ════════════════════════════════════════════════════════════════════
    ' REPORTING & VISUALIZATION
    ' ════════════════════════════════════════════════════════════════════
    package "Reporting" #E8F4F8 {
        usecase "Generate Stat Cards" as UC_Stat_Cards
        usecase "Generate Collection Chart" as UC_Collection_Chart
        usecase "Generate Growth Chart" as UC_Growth_Chart
        usecase "Generate Visitor Chart" as UC_Visitor_Chart
        usecase "Generate Utilization Chart" as UC_Utilization_Chart
        usecase "Generate Type Distribution Chart" as UC_Type_Chart
    }
    
    ' ════════════════════════════════════════════════════════════════════
    ' USER MANAGEMENT MODULE
    ' ════════════════════════════════════════════════════════════════════
    package "User Management" #E8F4F8 {
        usecase "View User List" as UC_User_List
        usecase "Create User Account" as UC_Create_User
        usecase "Edit User Account" as UC_Edit_User
        usecase "Delete User Account" as UC_Delete_User
        usecase "Assign Roles" as UC_Assign_Roles
    }
    
    ' ════════════════════════════════════════════════════════════════════
    ' SYSTEM CONFIGURATION MODULE
    ' ════════════════════════════════════════════════════════════════════
    package "System Configuration" #E8F4F8 {
        usecase "Configure Survey Status" as UC_Config_Status
        usecase "Set Active Year" as UC_Set_Year
        usecase "Manage Survey Questions" as UC_Manage_Questions
        usecase "Set Survey Period" as UC_Set_Period
        usecase "Configure Rate Limits" as UC_Config_Rate_Limits
    }
}

' ════════════════════════════════════════════════════════════════════
' ASSOCIATIONS: ADMIN
' ════════════════════════════════════════════════════════════════════
Admin --> UC_Login
Admin --> UC_View_Form
Admin --> UC_View_Recap
Admin --> UC_View_Charts
Admin --> UC_Export_Excel
Admin --> UC_View_Detail
Admin --> UC_User_List
Admin --> UC_Create_User
Admin --> UC_Edit_User
Admin --> UC_Delete_User
Admin --> UC_Config_Status
Admin --> UC_Set_Year
Admin --> UC_Manage_Questions
Admin --> UC_Set_Period
Admin --> UC_Logout

' ════════════════════════════════════════════════════════════════════
' ASSOCIATIONS: OPERATOR/STAFF
' ════════════════════════════════════════════════════════════════════
Operator --> UC_Login
Operator --> UC_View_Form
Operator --> UC_Input_Data
Operator --> UC_Submit
Operator --> UC_View_Recap
Operator --> UC_View_Charts
Operator --> UC_Export_Excel
Operator --> UC_View_Detail
Operator --> UC_Logout

' ════════════════════════════════════════════════════════════════════
' ASSOCIATIONS: GUEST/VIEWER
' ════════════════════════════════════════════════════════════════════
Guest --> UC_View_Charts
Guest --> UC_View_Recap

' ════════════════════════════════════════════════════════════════════
' INCLUDE RELATIONSHIPS (Mandatory - always happens)
' ════════════════════════════════════════════════════════════════════
UC_Input_Data ..> UC_Validate : <<include>>
UC_Submit ..> UC_Validate : <<include>>
UC_Submit ..> UC_Check_Rate : <<include>>
UC_Submit ..> UC_Double_Submit : <<include>>
UC_View_Recap ..> UC_Filter_Year : <<include>>
UC_View_Recap ..> UC_Sort_Data : <<include>>
UC_View_Charts ..> UC_Stat_Cards : <<include>>
UC_View_Charts ..> UC_Collection_Chart : <<include>>
UC_View_Charts ..> UC_Growth_Chart : <<include>>
UC_View_Charts ..> UC_Visitor_Chart : <<include>>
UC_View_Charts ..> UC_Utilization_Chart : <<include>>
UC_View_Charts ..> UC_Type_Chart : <<include>>
UC_Submit ..> UC_Confirmation : <<include>>

' ════════════════════════════════════════════════════════════════════
' EXTEND RELATIONSHIPS (Optional - conditional)
' ════════════════════════════════════════════════════════════════════
UC_View_Recap ..> UC_Filter_Date : <<extend>>
UC_View_Recap ..> UC_Filter_Nomor : <<extend>>
UC_View_Recap ..> UC_View_Detail : <<extend>>
UC_View_Recap ..> UC_Export_Excel : <<extend>>
UC_Export_Excel ..> UC_Export_Rate_Limit : <<include>>
UC_Manage_User ..> UC_Assign_Roles : <<include>>

note right of UC_Login
  Session established
  User role determined
end note

note right of UC_Input_Data
  Supports multiple
  data types and
  validation rules
end note

note right of UC_View_Charts
  Real-time statistics
  with caching for
  performance
end note

note right of UC_Export_Excel
  Streaming export
  supports unlimited
  records
end note

note right of UC_Config_Rate_Limits
  Prevents spam &
  abuse, protects
  system resources
end note

@enduml
