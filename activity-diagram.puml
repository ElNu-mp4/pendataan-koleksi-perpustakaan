@startuml

title Activity Diagram - User, Admin, and System Flow for Pendataan

|User|
start
:Open aplikasi pendataan;
if (Login sebagai admin?) then (ya)
  :Buka halaman login admin;
  :Masukkan kredensial;
else (tidak)
  if (Pilih Survey?) then (ya)
    :Submit survei;
  else (tidak)
    :Minta data rekap;
  endif
endif

|System|
if (Permintaan survei?) then (ya)
  :Cek survei aktif dan load config pendataan;
  :Validasi honeypot, rate limit, dan duplikasi;
  if (Validasi survei sukses?) then (ya)
    :Mulai transaksi database;
    :Simpan identitas_input_koleksi dan jawaban_koleksi;
    :Perbarui nomor pokok jika perlu;
    :Commit transaksi;
    :Hapus cache submission dan update rate limit;
    :Kirim halaman terima kasih;
  else (tidak)
    :Kirim pesan validasi gagal;
  endif
elseif (Permintaan rekap?) then (ya)
  :Query tahun tersedia dan filter rekap dari database;
  :Hitung agregat chart untuk get_chart_stats;
  if (Data chart tersedia?) then (ya)
    :Kirim JSON chart dan stat cards;
  else (tidak)
    :Kirim respons tidak ada data;
  endif
  :Query tabel rekap dengan pagination dan sorting;
  :Kirim JSON tabel rekap ke browser;
  :Tampilkan dashboard rekap dengan Chart.js dan tabel;
else (Admin login)
  :Validasi kredensial admin;
  if (Login valid?) then (ya)
    :Tampilkan dashboard admin;
  else (tidak)
    :Tampilkan pesan login gagal;
  endif
endif

|Admin|
if (Dashboard admin tersedia?) then (ya)
  :Pilih menu manajemen pendataan atau debug;
  if (Manajemen pendataan dipilih?) then (ya)
    :Buka daftar laporan pendataan;
    :Lakukan aksi CRUD atau lihat detail;
  else (tidak)
    :Buka halaman debug atau menu lain;
  endif
endif

stop

@enduml
